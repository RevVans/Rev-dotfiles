[global]
offset = (10, 10)
frame_width = 2
corner_radius = 8
font = iMWritingMono Nerd Font 10
frame_color = "#89b4fa"
separator_color= frame
highlight = "#89b4fa"
icon_path = ~/.icons/16/

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
